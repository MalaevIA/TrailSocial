@startuml TrailSocial_Deployment
!theme plain
title Диаграмма развёртывания — «Верста»

skinparam node {
    BackgroundColor #FFFBF5
    BorderColor #2D6A4F
}

node "Устройство пользователя\n(Android 8.0+)" as device {
    artifact "Верста.apk" as apk {
        component "Интерфейс\n(Jetpack Compose)" as ui
        component "Контейнер DI\n(Hilt)" as hilt
        component "HTTP-клиент\n(Retrofit + OkHttp)" as http
        component "Хранилище токенов\n(EncryptedSharedPrefs)" as token
        component "Настройки\n(DataStore)" as ds
        component "Картографический SDK\n(Yandex MapKit)" as mapkit
    }
}

node "Docker Host\n(Ubuntu 22.04)" as host {
    node "Контейнер приложения" as app {
        artifact "FastAPI + Uvicorn" as fastapi
        artifact "Миграции БД\n(Alembic)" as alembic
        folder "Файловое хранилище\n(uploads/)" as uploads
    }
    node "Контейнер базы данных" as dbcont {
        database "PostgreSQL 16\n(порт 5433)" as pg
    }
}

cloud "Внешние сервисы" as external {
    node "Yandex Cloud\n(Qwen 3 235B)" as gpt
    node "Yandex Geocoder API\n(геокодирование)" as geo
    node "OSRM\n(построение маршрутов)" as osrm
    node "Yandex MapKit API\n(тайлы карт)" as mapapi
}

' Связи клиента
ui --> hilt : внедрение зависимостей
hilt --> http
hilt --> token
hilt --> ds
ui --> mapkit

' Клиент → Сервер
http --> fastapi : HTTPS / REST + WebSocket\n/api/v1/*
note on link
  Формат: JSON
  Авторизация: Bearer JWT
  Таймаут: 30с / 120с / 60с
end note

' Сервер → БД и хранилище
fastapi --> pg : asyncpg\n(порт 5433)
alembic --> pg : миграции схемы
fastapi --> uploads : файловый ввод/вывод

' Сервер → внешние сервисы
fastapi --> gpt : HTTPS\n(генерация маршрута)
fastapi --> geo : HTTPS\n(геокодирование точек)
fastapi --> osrm : HTTP\n(пешая геометрия)

' MapKit SDK → API
mapkit --> mapapi : тайлы карт
mapkit --> geo : подсказки адресов

@enduml
